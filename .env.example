# Supabase configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Optional: compile settings
MAX_CONCURRENT_COMPILES=2
COMPILE_TIMEOUT_SECONDS=15
SEMAPHORE_WAIT_TIMEOUT_SECONDS=10
SIGNED_URL_TTL_SECONDS=3600

# Feature flags
ENABLE_COMPILE_CACHE=true
ENABLE_WORKDIR_CACHE=true
ENABLE_ADAPTIVE_ENGINE=true
ENABLE_COMPILE_COALESCING=true
ENABLE_STARTUP_WARMUP=false
ENABLE_REUSE_SIGNED_URL=true

COMPILE_CACHE_MAX_ENTRIES=500
WORKDIR_CACHE_ROOT=/tmp/texforge-workdirs
WORKDIR_CACHE_MAX_PROJECTS=30
